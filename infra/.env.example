# Infra – copy til infra/.env (eller sæt i shell)
# Bruges af docker-compose og scripts

POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=appdb

# Til scripts (host-URL til app-db)
DATABASE_URL=postgres://app:secret@localhost:5432/appdb

# PBF og data (scripts)
DATA_DIR=../data
PBF_URL_DK=https://download.geofabrik.de/europe/denmark-latest.osm.pbf
