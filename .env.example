# EzRoot – copy to .env and fill in

# API (NestJS)
API_PORT=3001
NODE_ENV=development

# Database (Postgres + PostGIS)
DATABASE_URL=postgres://app:secret@localhost:5432/appdb

# JWT
JWT_SECRET=change-me-in-production-min-32-chars

# GraphHopper (routing)
GRAPHHOPPER_URL=http://localhost:8989

# Martin (vector tiles) – frontend uses this for map
MARTIN_TILES_URL=http://localhost:6767

# Redis (optional – geocode cache)
REDIS_URL=redis://localhost:6379

# Geocode (optional – Nominatim; MVP can use coordinates only)
NOMINATIM_URL=
